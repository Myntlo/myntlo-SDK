{
  "name": "@myntlo/sdk",
  "version": "0.1.0",
  "description": "Official Myntlo API SDK for Node.js and modern browsers.",
  "license": "MIT",
  "homepage": "https://docs.myntlo.co",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Myntlo/myntlo-SDK.git"
  },
  "bugs": {
    "url": "https://github.com/Myntlo/myntlo-SDK/issues"
  },
  "keywords": [
    "myntlo",
    "meeting-transcription",
    "meeting-notes",
    "api-client",
    "sdk"
  ],
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts --max-warnings=0",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"tests/**/*.{ts,js}\" \"examples/**/*.{ts,js}\""
  },
  "devDependencies": {
    "@types/node": "^18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsup": "^8.0.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
