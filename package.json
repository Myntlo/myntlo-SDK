{
  "name": "@myntlo/sdk",
  "version": "0.1.0",
  "description": "Official Myntlo API SDK for Node.js and modern browsers.",
  "license": "MIT",
  "sideEffects": false,
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .js --max-warnings=0 --no-error-on-unmatched-pattern",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"tests/**/*.{ts,js}\" \"examples/**/*.{ts,js}\""
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsup": "^8.0.1",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5"
  }
}
